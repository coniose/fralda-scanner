{
  "expo": {
    "name": "FraldaScanner",
    "slug": "fralda-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.fraldascanner.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Precisamos da câmera para identificar fraldas na gôndola."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Usamos sua localização para encontrar produtos disponíveis na loja onde você está."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "949d9a12-8e75-4810-9c4d-f8bd5b28c9ab"
      }
    }
  }
}
